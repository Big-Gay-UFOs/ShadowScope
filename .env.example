# ShadowScope example environment (safe to commit)
# Copy this file to .env for local use (do NOT commit .env)

# Recommended: host CLI talks to Docker Postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/shadowscope

# Optional: local SQLite mode
# DATABASE_URL=sqlite:///./dev.db

# OpenSearch (used by tools/opensearch_reindex.py if you want env defaults)
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=shadowscope-events

# Optional: SAM.gov (disabled unless you wire it)
# SAM_API_KEY=your_key_here
# SAM_API_BASE_URL=https://api.sam.gov/prod/opportunities/v2/search
# SAM_API_TIMEOUT_SECONDS=60
# SAM_API_MAX_RETRIES=8
# SAM_API_BACKOFF_BASE=0.75
# PowerShell helper: .\examples\powershell\set-shadow-env.ps1
