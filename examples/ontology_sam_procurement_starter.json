{
  "version": "1",
  "defaults": {
    "fields": [
      "snippet",
      "raw_json"
    ]
  },
  "packs": [
    {
      "id": "sam_procurement_starter",
      "name": "SAM Procurement Starter",
      "enabled": true,
      "description": "Conservative starter ontology for common SAM.gov procurement concepts. Less aggressive than the demo ontology.",
      "weight": 1,
      "rules": [
        {
          "id": "combined_synopsis_solicitation",
          "type": "regex",
          "pattern": "Combined Synopsis/?Solicitation",
          "keywords": [
            "notice",
            "solicitation"
          ],
          "weight": 1
        },
        {
          "id": "solicitation",
          "type": "regex",
          "pattern": "\\bSolicitation\\b",
          "keywords": [
            "solicitation"
          ],
          "weight": 1
        },
        {
          "id": "sources_sought",
          "type": "regex",
          "pattern": "Sources Sought",
          "keywords": [
            "sources_sought",
            "market_research"
          ],
          "weight": 1
        },
        {
          "id": "presolicitation",
          "type": "regex",
          "pattern": "\\bPresolicitation\\b",
          "keywords": [
            "presolicitation"
          ],
          "weight": 1
        },
        {
          "id": "request_for_proposal",
          "type": "regex",
          "pattern": "\\bRFP\\b|Request for Proposal",
          "keywords": [
            "rfp"
          ],
          "weight": 1
        },
        {
          "id": "request_for_quote",
          "type": "regex",
          "pattern": "\\bRFQ\\b|Request for Quotation",
          "keywords": [
            "rfq"
          ],
          "weight": 1
        },
        {
          "id": "invitation_for_bid",
          "type": "regex",
          "pattern": "\\bIFB\\b|Invitation for Bid",
          "keywords": [
            "ifb"
          ],
          "weight": 1
        },
        {
          "id": "idiq",
          "type": "regex",
          "pattern": "\\bIDIQ\\b|Indefinite Delivery",
          "keywords": [
            "idiq"
          ],
          "weight": 1
        },
        {
          "id": "task_order",
          "type": "regex",
          "pattern": "\\btask order\\b",
          "keywords": [
            "task_order"
          ],
          "weight": 1
        },
        {
          "id": "small_business_set_aside",
          "type": "regex",
          "pattern": "small business set-?aside|set-?aside",
          "keywords": [
            "set_aside"
          ],
          "weight": 1
        },
        {
          "id": "naics",
          "type": "regex",
          "pattern": "\\bNAICS\\b",
          "keywords": [
            "naics"
          ],
          "weight": 1
        },
        {
          "id": "construction",
          "type": "regex",
          "pattern": "construction|repair|renovation",
          "keywords": [
            "construction"
          ],
          "weight": 1
        },
        {
          "id": "generator",
          "type": "regex",
          "pattern": "\\bgenerators?\\b",
          "keywords": [
            "generator"
          ],
          "weight": 1
        },
        {
          "id": "valve",
          "type": "regex",
          "pattern": "\\bvalves?\\b",
          "keywords": [
            "valve"
          ],
          "weight": 1
        },
        {
          "id": "water",
          "type": "regex",
          "pattern": "\\bwater\\b|\\bfeedwater\\b",
          "keywords": [
            "water"
          ],
          "weight": 1
        }
      ]
    }
  ]
}
