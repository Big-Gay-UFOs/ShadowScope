{
  "version": "2",
  "defaults": {
    "fields": [
      "snippet",
      "raw_json"
    ]
  },
  "packs": [
    {
      "id": "sam_procurement_starter",
      "name": "SAM Procurement Starter",
      "enabled": true,
      "description": "High-precision starter ontology for SAM.gov research pivots. Rules favor notice metadata and procurement context over broad single-word matches.",
      "weight": 1,
      "rules": [
        {
          "id": "notice_type_sources_sought",
          "type": "regex",
          "pattern": "(?:\\\"sam_notice_type\\\"|\\\"noticeType\\\"):\\\"[^\\\"]*sources sought[^\\\"]*\\\"|\\bSources Sought\\b",
          "weight": 2
        },
        {
          "id": "notice_type_combined_synopsis_solicitation",
          "type": "regex",
          "pattern": "(?:\\\"sam_notice_type\\\"|\\\"noticeType\\\"):\\\"[^\\\"]*combined synopsis/?solicitation[^\\\"]*\\\"|Combined Synopsis/?Solicitation",
          "weight": 2
        },
        {
          "id": "notice_type_presolicitation",
          "type": "regex",
          "pattern": "(?:\\\"sam_notice_type\\\"|\\\"noticeType\\\"):\\\"[^\\\"]*presolicitation[^\\\"]*\\\"|\\bPresolicitation\\b",
          "weight": 2
        },
        {
          "id": "notice_type_solicitation",
          "type": "regex",
          "pattern": "(?:\\\"sam_notice_type\\\"|\\\"noticeType\\\"):\\\"[^\\\"]*solicitation[^\\\"]*\\\"|\\bSolicitation\\b",
          "weight": 1
        },
        {
          "id": "request_for_proposal",
          "type": "regex",
          "pattern": "\\bRFP\\b|Request for Proposal",
          "weight": 2
        },
        {
          "id": "request_for_quote",
          "type": "regex",
          "pattern": "\\bRFQ\\b|Request for Quotation",
          "weight": 2
        },
        {
          "id": "invitation_for_bid",
          "type": "regex",
          "pattern": "\\bIFB\\b|Invitation for Bid",
          "weight": 2
        },
        {
          "id": "idiq_vehicle",
          "type": "regex",
          "pattern": "\\bIDIQ\\b|Indefinite Delivery(?:,? Indefinite Quantity)?",
          "weight": 2
        },
        {
          "id": "task_or_delivery_order",
          "type": "regex",
          "pattern": "\\b(task|delivery) order\\b",
          "weight": 2
        },
        {
          "id": "naics_context",
          "type": "regex",
          "pattern": "(?:\\\"sam_naics_code\\\"|\\\"naicsCode\\\"):\\\"[0-9A-Z]{2,}\\\"|\\bNAICS\\b",
          "weight": 2
        },
        {
          "id": "set_aside_context",
          "type": "regex",
          "pattern": "(?:\\\"sam_set_aside_(?:code|description)\\\"|\\\"typeOfSetAside(?:Description)?\\\"):\\\"[^\\\"]*(?:small business|sba|8\\(a\\)|hubzone|sdvosb|wosb)[^\\\"]*\\\"|small business set-?aside",
          "weight": 2
        },
        {
          "id": "response_deadline_present",
          "type": "regex",
          "pattern": "(?:\\\"sam_response_deadline\\\"|\\\"responseDeadLine\\\"|\\\"responseDeadline\\\"):\\\"[^\\\"]+\\\"",
          "weight": 1
        },
        {
          "id": "solicitation_number_present",
          "type": "regex",
          "pattern": "(?:\\\"sam_solicitation_number\\\"|\\\"solicitationNumber\\\"):\\\"[^\\\"]+\\\"",
          "weight": 1
        },
        {
          "id": "agency_path_code_present",
          "type": "regex",
          "pattern": "(?:\\\"sam_agency_path_code\\\"|\\\"fullParentPathCode\\\"):\\\"[^\\\"]+\\\"",
          "weight": 1
        }
      ]
    }
  ]
}
