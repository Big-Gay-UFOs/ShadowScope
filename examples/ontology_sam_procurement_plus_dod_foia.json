                                        "fields":  [
                                                       "snippet",
                                                       "raw_json"
                                                   ],
                                        "weight":  1
                                    },
                                    {
                                        "id":  "archival_program_handle_procurement_probe",
                                        "type":  "regex",
                                        "pattern":  "\\b(?:Project Sentient|Recent Sentient Highlights|Deep Submergence Systems Project|DSSP|Project Sand Dollar|Project Jennifer|Project Azorian|OPNAV\\s*3820|Project Sundance|Project Palladium|Operation Fishbowl|Bluegill Triple Prime)\\b.{0,180}\\b(?:contract|solicitation|task order|IDIQ|sole source|support|analysis|program support|historical research|FOIA)\\b",
