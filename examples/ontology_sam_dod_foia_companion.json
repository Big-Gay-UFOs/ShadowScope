{
  "version": "2",
  "defaults": {
    "fields": [
      "snippet",
      "raw_json"
    ]
  },
  "packs": [
    {
      "id": "sam_dod_program_protection_sap",
      "name": "SAM DoD Program Protection and SAP",
      "enabled": true,
      "description": "Contextual indicators for AFOSI/SAP security and program protection work where procurement language is present.",
      "weight": 1,
      "rules": [
        {
          "id": "afosi_program_security_context",
          "type": "regex",
          "pattern": "\\b(?:AFOSI|Office of Special Investigations)\\b.{0,120}\\b(?:program protection|program security|industrial security|special access(?:\\s+program)?|SAP security)\\b",
          "fields": [
            "snippet",
            "raw_json"
          ],
          "weight": 2
        },
        {
          "id": "sap_facility_modernization_context",
          "type": "regex",
          "pattern": "\\b(?:special access(?:\\s+program)?|SAP(?:\\s+security)?|SCIF|sensitive compartmented information facility)\\b.{0,140}\\b(?:facility|infrastructure|modernization|upgrade|hardening|renovation)\\b",
          "fields": [
            "snippet",
            "raw_json"
          ],
          "weight": 2
        },
        {
          "id": "program_protection_plan_support",
          "type": "regex",
          "pattern": "\\b(?:program protection plan|PPP|trusted systems?|classified integration)\\b.{0,120}\\b(?:support|implementation|assessment|compliance|engineering)\\b",
          "fields": [
            "snippet",
            "raw_json"
          ],
          "weight": 1
        }
      ]
    },
    {
      "id": "sam_dod_flight_test_range_instrumentation",
      "name": "SAM DoD Flight Test and Range Instrumentation",
      "enabled": true,
      "description": "Flight test and range instrumentation cues tied to Edwards/412th/Plant 42 and NAWCWD China Lake contexts.",
      "weight": 1,
      "rules": [
        {
          "id": "edwards_412th_plant42_range_context",
          "type": "regex",
          "pattern": "\\b(?:Edwards(?:\\s+AFB)?|412th(?:\\s+Test Wing)?|Plant\\s*42)\\b.{0,140}\\b(?:flight test|test and evaluation|T&E|range instrumentation|telemetry|mission instrumentation)\\b",
          "fields": [
            "snippet",
            "raw_json"
          ],
          "weight": 2
        },
        {
          "id": "nawcwd_china_lake_instrumentation_context",
          "type": "regex",
          "pattern": "\\b(?:NAWCWD|Naval Air Warfare Center Weapons Division|China Lake)\\b.{0,140}\\b(?:telemetry|instrumentation|flight test|T&E integration|test and evaluation integration)\\b",
          "fields": [
            "snippet",
            "raw_json"
          ],
          "weight": 2
        },
        {
          "id": "range_telemetry_support_services",
          "type": "regex",
          "pattern": "\\b(?:range instrumentation|telemetry systems?|data acquisition systems?)\\b.{0,120}\\b(?:integration|sustainment|engineering support|operations support)\\b",
          "fields": [
            "snippet",
            "raw_json"
          ],
          "weight": 1
        }
      ]
    },
    {
      "id": "sam_dod_advanced_aerospace_support",
      "name": "SAM DoD Advanced Aerospace Support",
      "enabled": true,
      "description": "Advanced aerospace and low-observable integration cues with explicit engineering/support context.",
      "weight": 1,
      "rules": [
        {
          "id": "low_observable_rcs_support_context",
          "type": "regex",
          "pattern": "\\b(?:low observable|radar cross section|RCS|signature management)\\b.{0,140}\\b(?:analysis|model(?:ing)?|test|integration|engineering support)\\b",
          "fields": [
            "snippet",
            "raw_json"
          ],
          "weight": 2
        },
        {
          "id": "advanced_air_vehicle_integration_context",
          "type": "regex",
          "pattern": "\\b(?:advanced aerospace|air vehicle|aerospace platform|airframe)\\b.{0,140}\\b(?:systems integration|mission systems integration|prototype integration|platform integration)\\b",
          "fields": [
            "snippet",
            "raw_json"
          ],
          "weight": 1
        },
        {
          "id": "survivability_materials_aerospace_support",
          "type": "regex",
          "pattern": "\\b(?:survivability|electromagnetic signature|materials integration)\\b.{0,120}\\b(?:aircraft|aerospace)\\b.{0,120}\\b(?:support|integration|engineering)\\b",
          "fields": [
            "snippet",
            "raw_json"
          ],
          "weight": 1
        }
      ]
    },
    {
      "id": "sam_dod_intel_recovery_undersea_support",
      "name": "SAM DoD Intel Recovery and Undersea Support",
      "enabled": true,
      "description": "ONR/ONI/NRO/NGA/SOCOM-adjacent procurement cues plus undersea recovery and technical support context.",
      "weight": 1,
      "rules": [
        {
          "id": "intel_org_support_context",
          "type": "regex",
          "pattern": "\\b(?:ONR|Office of Naval Research|ONI|Office of Naval Intelligence|NRO|National Reconnaissance Office|NGA|National Geospatial-Intelligence Agency|SOCOM|USSOCOM)\\b.{0,160}\\b(?:technical support|program support|operations support|integration support|analysis support|engineering support)\\b",
          "fields": [
            "snippet",
            "raw_json"
          ],
          "weight": 2
        },
        {
          "id": "undersea_recovery_support_context",
          "type": "regex",
          "pattern": "\\b(?:undersea|subsea|maritime|ocean)\\b.{0,140}\\b(?:recovery|salvage|sensor|acoustic|ISR|collection)\\b.{0,140}\\b(?:support|integration|services|operations)\\b",
          "fields": [
            "snippet",
            "raw_json"
          ],
          "weight": 2
        },
        {
          "id": "sensitive_recovery_exploitation_support",
          "type": "regex",
          "pattern": "\\b(?:foreign material exploitation|FME|materiel recovery|sensitive site exploitation|technical exploitation)\\b.{0,140}\\b(?:support|analysis|logistics|integration|operations)\\b",
          "fields": [
            "snippet",
            "raw_json"
          ],
          "weight": 1
        }
      ]
    },
    {
      "id": "operational_noise_terms",
      "name": "Operational Noise Terms",
      "enabled": true,
      "description": "SAM commodity/admin suppressors for NSN line-item buys, medical/clinical purchases, and event/hospitality noise.",
      "weight": 1,
      "rules": [
        {
          "id": "nsn_line_item_commodity_noise",
          "type": "regex",
          "pattern": "\\b(?:NSN|National Stock Number|FSC|Federal Supply Class|CLIN)\\b.{0,120}\\b(?:bolt|valve|gasket|filter|bearing|hose|nut|screw|commodity|line item|spare parts?)\\b",
          "fields": [
            "snippet",
            "raw_json"
          ],
          "weight": 1
        },
        {
          "id": "nsn_part_number_quantity_noise",
          "type": "regex",
          "pattern": "\\b\\d{4}-\\d{2}-\\d{3}-\\d{4}\\b.{0,80}\\b(?:qty|quantity|unit price|part(?:\\s+number)?|NSN)\\b",
          "fields": [
            "snippet",
            "raw_json"
          ],
          "weight": 1
        },
        {
          "id": "medical_clinical_procurement_noise",
          "type": "regex",
          "pattern": "\\b(?:hospital|medical center|clinic|pharmacy|dental|clinical)\\b.{0,140}\\b(?:staffing|supplies|equipment|services|patient care|laboratory)\\b",
          "fields": [
            "snippet",
            "raw_json"
          ],
          "weight": 1
        },
        {
          "id": "event_hospitality_admin_noise",
          "type": "regex",
          "pattern": "\\b(?:conference|workshop|seminar|symposium|training event|town hall)\\b.{0,140}\\b(?:venue|catering|lodging|hospitality|audio[ -]?visual|A/V|event support)\\b",
          "fields": [
            "snippet",
            "raw_json"
          ],
          "weight": 1
        },
        {
          "id": "admin_facility_ops_noise",
          "type": "regex",
          "pattern": "\\b(?:office supplies|janitorial|custodial|grounds maintenance|furniture|copy paper|toner|mailroom)\\b.{0,120}\\b(?:delivery|services?|purchase|procurement)\\b",
          "fields": [
            "snippet",
            "raw_json"
          ],
          "weight": 1
        }
      ]
    }
  ]
}
